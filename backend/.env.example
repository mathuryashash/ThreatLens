# Database Configuration
# Direct connection to PostgreSQL (e.g., Supabase transaction pooler or direct connection string)
DATABASE_URL=your-supabase-postgresql-connection-string

# Supabase API Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LLM Configuration
# Options: groq | gemini (default: groq)
# In production, set THREATLENS_ALLOW_MOCK_DB=false. In local dev, set it to true.
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
THREATLENS_ALLOW_MOCK_DB=true

# Server Configuration
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
LLM_PROMPT_VERSION=v1.0
